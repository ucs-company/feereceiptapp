.sign-left { font-size: 8px; color: var(--dark); line-height: 1.7; }
.sign-left strong { font-size: 10px; color: var(--navy); font-family: 'Merriweather', serif; }

/* Stamp */
.stamp-wrap { display: flex; flex-direction: column; align-items: center; gap: 3px; }
.stamp {
  width: 80px; height: 80px; border-radius: 50%;
  border: 2.5px double var(--royal);
  background: radial-gradient(circle, rgba(220,232,251,0.4) 0%, rgba(255,255,255,0) 70%);
  display: flex; align-items: center; justify-content: center;
  position: relative;
}
.stamp::before {
  content: '';
  position: absolute; inset: 4px; border-radius: 50%;
  border: 1px solid var(--border);
}
.stamp-in { text-align: center; z-index: 1; }
.stamp-in svg { width: 20px; height: 20px; fill: var(--royal); opacity: 0.75; display: block; margin: 0 auto 2px; }
.stamp-in .s1 { font-size: 6px; font-weight: 700; color: var(--royal); letter-spacing: 0.5px; line-height: 1.3; display: block; }
.stamp-in .s2 { font-size: 6px; color: var(--soft); letter-spacing: 1px; display: block; margin-top: 1px; }
.stamp-cap { font-size: 7.5px; color: var(--soft); letter-spacing: 0.3px; }

/* ===== FOOTER STRIP ===== */
