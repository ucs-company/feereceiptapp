.hdr-sub { font-size: 7px; color: #fff; letter-spacing: 2px; text-transform: uppercase; margin-top: 3px; }
.hdr-reg { font-size: 7px; color: #fff; margin-top: 4px; line-height: 1.5; }

/* Right rectangular logo */
.logo-rect {
  width: 98px; height: 56px;
  border: 1.5px dashed rgba(255,255,255,0.3);
  border-radius: 4px;
  background: rgba(255,255,255,0.08);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}
.logo-rect svg { width: 20px; height: 20px; fill: rgba(255,255,255,0.35); }
.logo-rect span { font-size: 6.5px; color: rgba(255,255,255,0.4); margin-top: 3px; text-align: center; letter-spacing: 0.3px; }

/* ===== TITLE BAR ===== */
.title-bar {
  background: #009BD4;
