  background: #fff;
}

/* ===== OUTER PAGE ===== */
.page {
  width: 190mm;
  min-height: 277mm;
  margin: 0 auto;
  background: #fff;
  border: 1.5px solid var(--border);
  border-radius: 3px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ===== TOP ACCENT BAR ===== */
