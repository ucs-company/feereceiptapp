  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.4);
  background: rgba(255,255,255,0.12);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  flex-shrink: 0;
}
.logo-circle svg { width: 26px; height: 26px; fill: rgba(255,255,255,0.8); }
.logo-circle span { font-size: 6.5px; color: rgba(255,255,255,0.75); text-align: center; margin-top: 2px; letter-spacing: 0.3px; line-height: 1.2; }

/* Centre org info */
