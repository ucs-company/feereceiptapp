.tax-note::before { content: "✦"; font-size: 11px; }

/* ── CLOSING ── */
.closing { font-size: 8.5px; color: var(--mid); line-height: 1.65; margin-bottom: 8px; }

/* ── SIGN ROW ── */
.sign-row {
